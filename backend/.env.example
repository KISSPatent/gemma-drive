DJANGO_SECRET_KEY=replace-me-run-get_random_secret_key
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173
DJANGO_DEBUG=True

# Defaults match local Ollama install
# OLLAMA_MODEL=gemma3:4b   # smaller fallback if gemma4:e4b isn't available
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# Optional — only used by the unused Google Picker integration
# (see frontend/src/hooks/useGooglePicker.ts). Safe to leave blank.
GOOGLE_PICKER_API_KEY=
GOOGLE_PROJECT_NUMBER=